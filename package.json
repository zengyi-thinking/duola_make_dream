{
  "name": "pocketbuddy-agent",
  "description": "PocketBuddy — 把模糊想法放进口袋，再拿出一个小产品雏形",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "predev": "node scripts/inject-dev-config.mjs",
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox",
    "prebuild": "node scripts/inject-dev-config.mjs",
    "build": "node scripts/run-build-step.mjs ./node_modules/wxt/bin/wxt.mjs build",
    "build:firefox": "node scripts/run-build-step.mjs ./node_modules/wxt/bin/wxt.mjs build -b firefox",
    "zip": "node scripts/run-build-step.mjs ./node_modules/wxt/bin/wxt.mjs zip",
    "zip:firefox": "node scripts/run-build-step.mjs ./node_modules/wxt/bin/wxt.mjs zip -b firefox",
    "precompile": "node scripts/inject-dev-config.mjs",
    "compile": "node scripts/run-build-step.mjs ./node_modules/typescript/bin/tsc --noEmit",
    "privacy-check": "node scripts/privacy-check.mjs",
    "postinstall": "node scripts/inject-dev-config.mjs && wxt prepare"
  },
  "dependencies": {
    "@types/d3-force": "^3.0.10",
    "d3-force": "^3.0.0",
    "framer-motion": "^12.40.0",
    "html2canvas-pro": "^2.0.4",
    "idb": "^8.0.2",
    "jspdf": "^4.2.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "three": "^0.184.0"
  },
  "devDependencies": {
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.6",
    "@types/three": "^0.184.1",
    "@wxt-dev/module-react": "^1.1.5",
    "puppeteer-core": "^25.1.0",
    "sharp": "^0.35.1",
    "typescript": "^5.8.3",
    "ws": "^8.21.0",
    "wxt": "^0.20.20"
  }
}
